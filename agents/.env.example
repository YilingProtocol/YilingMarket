# Base Sepolia RPC
RPC_URL=https://sepolia.base.org

# Deployed PredictionMarket contract address
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Treasury address for protocol fees
TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS_HERE

# OpenAI API Key (for AI agents)
OPENAI_API_KEY=sk-your-openai-key-here

# LLM Model to use
LLM_MODEL=gpt-4o-mini

# Agent private keys (one per agent, indexed 1-7)
# Each agent needs its own funded wallet on Base Sepolia
# Get ETH from faucet: https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
# Agents without keys will be skipped at startup
AGENT_KEY_1=0xYOUR_PRIVATE_KEY_1   # Analyst
AGENT_KEY_2=0xYOUR_PRIVATE_KEY_2   # Bayesian
AGENT_KEY_3=0xYOUR_PRIVATE_KEY_3   # Economist
AGENT_KEY_4=0xYOUR_PRIVATE_KEY_4   # Statistician
AGENT_KEY_5=0xYOUR_PRIVATE_KEY_5   # CrowdSynth
AGENT_KEY_6=0xYOUR_PRIVATE_KEY_6   # Contrarian
AGENT_KEY_7=0xYOUR_PRIVATE_KEY_7   # Historian
